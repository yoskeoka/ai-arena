{
  "name": "@yoskeoka/ai-arena-operator-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "NODE_OPTIONS=--disable-warning=DEP0205 playwright test",
    "verify:local": "OPERATOR_UI_LANE=fixture-local NODE_OPTIONS=--disable-warning=DEP0205 ../tools/dev/run-operator-ui-playwright.sh",
    "verify:local:auth": "OPERATOR_UI_LANE=auth-local NODE_OPTIONS=--disable-warning=DEP0205 ../tools/dev/run-operator-ui-playwright.sh",
    "verify:local:real": "OPERATOR_UI_LANE=real-local NODE_OPTIONS=--disable-warning=DEP0205 ../tools/dev/run-operator-ui-playwright.sh",
    "verify:ci:auth": "OPERATOR_UI_LANE=ci-auth NODE_OPTIONS=--disable-warning=DEP0205 ../tools/dev/run-operator-ui-playwright.sh",
    "verify:ci:file-backed": "OPERATOR_UI_LANE=ci-file-backed NODE_OPTIONS=--disable-warning=DEP0205 ../tools/dev/run-operator-ui-playwright.sh",
    "verify:ci:postgres": "OPERATOR_UI_LANE=ci-postgres NODE_OPTIONS=--disable-warning=DEP0205 ../tools/dev/run-operator-ui-playwright.sh",
    "verify:remote": "OPERATOR_UI_LANE=remote NODE_OPTIONS=--disable-warning=DEP0205 ../tools/dev/run-operator-ui-playwright.sh"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.5.2",
    "@playwright/test": "1.54.1",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.6",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "vite": "6.3.5"
  }
}
